<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/background_checklist"
    tools:context=".CheckList">

    <!-- Progress header card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardProgress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginTop="8dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="1dp"
        app:strokeWidth="0dp"
        app:cardBackgroundColor="@color/surface_card">

        <TextView
            android:id="@+id/txtProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingTop="12dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp"
            android:text="Packed 0 of 0"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold" />
    </com.google.android.material.card.MaterialCardView>

    <androidx.recyclerview.widget.RecyclerView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:id="@+id/recyclerView"
        android:layout_below="@id/cardProgress"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="64dp"
        android:clipToPadding="false"
        android:paddingTop="4dp"
        android:paddingBottom="8dp" />

    <!-- Bottom add bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:id="@+id/linearLayout"
        android:background="@color/surface_card"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="8dp">

        <EditText
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="40dp"
            android:id="@+id/txtAdd"
            android:hint="Add new item…"
            android:textSize="15sp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:background="@drawable/checklist_add_bar_bg"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:singleLine="true" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnAdd"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:src="@android:drawable/ic_input_add"
            android:contentDescription="Add"
            app:fabSize="mini"
            app:backgroundTint="@color/accent"
            app:tint="@color/white"
            app:elevation="2dp" />
    </LinearLayout>
</RelativeLayout>