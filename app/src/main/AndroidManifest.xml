<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />


    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/app_icon_two"
        android:label="@string/app_name"
        android:roundIcon="@drawable/app_icon_two"
        android:supportsRtl="true"
        android:theme="@style/Theme.PackYourBag"
        tools:targetApi="31">
        <activity
            android:name=".MainActivity"
            android:exported="false" />
        <activity
            android:name=".TripProfileActivity"
            android:exported="false"
            android:theme="@style/Theme.PackYourBag.WithToolbar" />
        <activity
            android:name=".TripsActivity"
            android:exported="false"
            android:theme="@style/Theme.PackYourBag.WithToolbar" />
        <activity
            android:name=".AboutUs"
            android:exported="false"
            android:theme="@style/Theme.PackYourBag.WithToolbar" />
        <activity
            android:name=".CheckList"
            android:exported="false"
            android:theme="@style/Theme.PackYourBag.WithToolbar" />
        <activity
            android:name=".BdApps_Backend.LandingActivity"
            android:exported="false" />
        <activity
            android:name=".BdApps_Backend.MobileNumberActivity"
            android:exported="false"
            android:theme="@style/Theme.PackYourBag.WithToolbar" />
        <activity
            android:name=".BdApps_Backend.OTPActivity"
            android:exported="false"
            android:theme="@style/Theme.PackYourBag.WithToolbar" />
        <activity
            android:name=".SplashScreen"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <receiver
            android:name=".PackingReminderReceiver"
            android:exported="false" />
    </application>

</manifest>